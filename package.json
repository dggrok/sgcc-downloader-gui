{
  "name": "sgcc-downloader-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "SGCC cross-platform desktop app powered by Electron and Node.js",
  "main": "out/main/index.js",
  "author": "CodexDemo",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist": "pnpm build && electron-builder",
    "dist:win": "pnpm build && electron-builder --win nsis portable",
    "dist:win:dir": "pnpm build && electron-builder --win dir",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@ant-design/icons": "^6.0.0",
    "antd": "^5.27.6",
    "axios": "^1.8.4",
    "axios-cookiejar-support": "^6.0.4",
    "electron-log": "^5.2.4",
    "electron-store": "^10.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tough-cookie": "^5.1.1",
    "yazl": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.1",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "nock": "^14.0.4",
    "typescript": "^5.8.3",
    "vite": "^6.2.4",
    "vitest": "^3.1.1"
  },
  "build": {
    "appId": "com.codexdemo.sgccdownloader",
    "productName": "SGCC 公告附件下载工具",
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets/app_preview.png",
        "to": "app-assets/app_preview.png"
      },
      {
        "from": "assets/app.ico",
        "to": "app-assets/app.ico"
      }
    ],
    "asar": true,
    "mac": {
      "icon": "assets/app_preview.png",
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "icon": "assets/app.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
